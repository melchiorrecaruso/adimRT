  result.fm13 := -ALeft.fm2 * ARight.fm123;
  result.fm23 :=  ALeft.fm1 * ARight.fm123;
end;

class operator TCL3Vector.*(const ALeft: TCL3Trivector; const ARight: TCL3Vector): TCL3Bivector;
